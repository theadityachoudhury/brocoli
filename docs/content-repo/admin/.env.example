# Copy to .env.local — never commit .env.local

# GitHub PAT with Contents:read+write on your blog-content repo
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
VITE_GITHUB_OWNER=theadityachoudhury
VITE_GITHUB_REPO=blog-content
VITE_GITHUB_BRANCH=main

# Supabase — use the SERVICE ROLE key (not anon key) so writes bypass RLS
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_SERVICE_KEY=eyJ...

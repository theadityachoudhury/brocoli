# SEO / Site identity
VITE_SITE_NAME=Notes
VITE_SITE_URL=https://your-domain.com
VITE_SITE_DESCRIPTION=Personal notes and articles.
VITE_AUTHOR_NAME=Your Name

# Supabase project URL (from Project Settings > API)
VITE_SUPABASE_URL=

# Supabase anon key (from Project Settings > API)
VITE_SUPABASE_ANON_KEY=

# Supabase service_role key — only needed to run scripts/migrate-content.ts once
SUPABASE_SERVICE_KEY=

# GitHub PAT with contents:read on blog-content — only needed to run scripts/migrate-content.ts once
CONTENT_REPO_TOKEN=

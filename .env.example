# GitHub PAT with contents:read scope on the blog-content repo
CONTENT_REPO_TOKEN=

# Your GitHub username or org
CONTENT_REPO_OWNER=

# Name of your content repo (e.g. blog-content)
CONTENT_REPO_NAME=

# Supabase project URL (from Project Settings > API)
VITE_SUPABASE_URL=

# Supabase anon key (from Project Settings > API)
VITE_SUPABASE_ANON_KEY=
